{
	"name": "@w3rone/json-schema-form",
	"version": "0.0.0-development",
	"description": "Render forms based on JSON Schema definitions with React",
	"type": "module",
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"files": [
		"lib"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"test": "vitest --run --project=unit",
		"test:watch": "vitest --project=unit",
		"build": "tsc --project tsconfig.build.json",
		"prepublishOnly": "npm run build",
		"lint": "eslint src",
		"typecheck": "tsc --project tsconfig.build.json",
		"semantic-release": "semantic-release",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test-storybook": "vitest --project=storybook"
	},
	"author": "Cyrille Perois <cyrille.perois@w3r.one>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/w3r-one/json-schema-form.git"
	},
	"peerDependencies": {
		"react": "^18.2.0 || ^19.0.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^4.1.3",
		"@storybook/addon-a11y": "^10.1.11",
		"@storybook/addon-docs": "^10.1.11",
		"@storybook/addon-vitest": "^10.1.11",
		"@storybook/react-vite": "^10.1.11",
		"@testing-library/dom": "^10.1.0",
		"@testing-library/jest-dom": "^6.1.2",
		"@testing-library/react": "^16.0.0",
		"@types/lodash.get": "^4.4.7",
		"@types/lodash.set": "^4.3.7",
		"@types/node": "^22.10.2",
		"@types/react": "^18.0.35",
		"@types/react-dom": "^18.0.11",
		"@typescript-eslint/eslint-plugin": "^8.0.0",
		"@typescript-eslint/parser": "^8.0.0",
		"@semantic-release/exec": "^7.0.0",
		"@vitest/browser-playwright": "^4.0.16",
		"@vitest/coverage-v8": "^4.0.16",
		"eslint": "^8.39.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-react": "^7.32.2",
		"eslint-plugin-storybook": "^0.12.0",
		"jsdom": "^20.0.3",
		"playwright": "^1.57.0",
		"prettier": "^3.0.1",
		"prop-types": "^15.8.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"semantic-release": "^24.0.0",
		"storybook": "^10.1.11",
		"typescript": "^5.0.4",
		"vitest": "^4.0.16"
	},
	"dependencies": {
		"immer": "^10.0.2",
		"lodash.get": "^4.4.2",
		"lodash.set": "^4.3.2",
		"react-error-boundary": "^4.0.3",
		"remeda": "^2.0.3",
		"ts-pattern": "^5.0.1"
	},
	"release": {
		"branches": ["main", "next"],
		"plugins": [
			"@semantic-release/commit-analyzer",
			"@semantic-release/release-notes-generator",
			[
				"@semantic-release/exec",
				{
					"prepareCmd": "npm version ${nextRelease.version} --no-git-tag-version",
					"publishCmd": "npm publish --provenance"
				}
			],
			"@semantic-release/github"
		]
	}
}
